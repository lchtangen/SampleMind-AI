root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python, Rust, C++
[*.{py,rs,cpp,h}]
indent_style = space
indent_size = 4

# Web / config files
[*.{js,ts,svelte,json,yaml,yml,toml,css,html}]
indent_style = space
indent_size = 2

# Markdown — preserve trailing spaces (line breaks)
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab

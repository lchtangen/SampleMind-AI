# ══════════════════════════════════════════════════════════════════════════════
# SampleMind-AI — Environment Variables Reference
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is listed in .gitignore.
#
# Generate secure random secrets:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ══════════════════════════════════════════════════════════════════════════════

# ── AI / Auggie CLI ───────────────────────────────────────────────────────────
# Required for Auggie CLI, AI features, and future semantic search
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── Security (REQUIRED in production) ────────────────────────────────────────
# JWT signing key — MUST be changed from default before deployment
# Default in code is insecure: "change-me-before-deployment-abc123"
SAMPLEMIND_SECRET_KEY=REPLACE_WITH_RANDOM_32_CHAR_HEX

# Flask session encryption key (separate from JWT key)
FLASK_SECRET_KEY=REPLACE_WITH_ANOTHER_RANDOM_32_CHAR_HEX

# ── Database (optional overrides) ────────────────────────────────────────────
# Default (dev):  ~/.samplemind/library.db
# Default (macOS prod): ~/Library/Application Support/SampleMind/samplemind.db
SAMPLEMIND_DB_PATH=

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: debug | info | warning | error
SAMPLEMIND_LOG_LEVEL=info

# ── Performance ───────────────────────────────────────────────────────────────
# Parallel workers for batch import (0 = auto, uses cpu_count)
SAMPLEMIND_WORKERS=0

# ── Error Tracking (opt-in) ───────────────────────────────────────────────────
# Leave blank to disable Sentry completely
SAMPLEMIND_SENTRY_DSN=

# ── OAuth Providers (optional — for future multi-user auth) ──────────────────
# Google OAuth2 (requires Google Cloud Console setup)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth2 (requires GitHub OAuth App setup)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── macOS Code Signing & Notarization (production builds only) ───────────────
# Required for: pnpm tauri build + xcrun notarytool
# Identity example: "Developer ID Application: Your Name (TEAMID)"
APPLE_SIGNING_IDENTITY=
APPLE_TEAM_ID=
APPLE_ID=
# App-specific password (generate at appleid.apple.com)
APPLE_PASSWORD=

# ── Windows Code Signing (production builds only) ────────────────────────────
# Azure Trusted Signing (replaces EV code signing certificates)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_CODE_SIGNING_ACCOUNT=
AZURE_CERTIFICATE_PROFILE=

# ── GitHub Actions (CI/CD secrets — set in GitHub repo settings) ─────────────
# These are NOT set locally — configure them in:
# GitHub → repo → Settings → Secrets and variables → Actions
#
# Secrets to configure in GitHub:
#   ANTHROPIC_API_KEY          (for AI-powered CI features)
#   SAMPLEMIND_SECRET_KEY      (for integration tests)
#   APPLE_SIGNING_IDENTITY     (macOS release builds)
#   APPLE_TEAM_ID
#   APPLE_ID
#   APPLE_PASSWORD
#   AZURE_CLIENT_ID            (Windows release builds)
#   AZURE_TENANT_ID
#   AZURE_CLIENT_SECRET

# ── Sidecar Socket (override default path) ───────────────────────────────────
# Default: /tmp/samplemind.sock
SAMPLEMIND_SOCKET_PATH=

# ── Flask Service Configuration ───────────────────────────────────────────────
# Port for Flask web UI (default: 5000; use 5174 for Tauri dev mode)
FLASK_PORT=5000

# ── FastAPI Configuration ─────────────────────────────────────────────────────
# Host and port for FastAPI REST API (default: 127.0.0.1:8000)
SAMPLEMIND_API_HOST=127.0.0.1
SAMPLEMIND_API_PORT=8000


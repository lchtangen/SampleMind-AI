{
  // ── Python ──────────────────────────────────────────────────────────────────
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/src"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.inlayHints.functionReturnTypes": true,

  // ── Linting and formatting (ruff handles lint + format + imports) ───────────
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports.ruff": "explicit",
    "source.fixAll.ruff": "explicit"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  // ── Svelte (Phase 6 frontend) ───────────────────────────────────────────────
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "svelte.enable-ts-plugin": true,

  // ── TypeScript / JavaScript ─────────────────────────────────────────────────
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.tabSize": 2
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },

  // ── Rust (Tauri backend) ────────────────────────────────────────────────────
  "rust-analyzer.linkedProjects": [
    "app/src-tauri/Cargo.toml"
  ],
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.extraArgs": ["--", "-D", "warnings"],
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },

  // ── C++ (JUCE plugin, Phase 8) ──────────────────────────────────────────────
  "[cpp]": {
    "editor.tabSize": 4,
    "editor.detectIndentation": false
  },
  "C_Cpp.clang_format_style": "{ BasedOnStyle: LLVM, IndentWidth: 4, ColumnLimit: 100 }",

  // ── Test runner ─────────────────────────────────────────────────────────────
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "tests"
  ],

  // ── Audio file associations (treat as binary, no diff) ──────────────────────
  "files.associations": {
    "*.wav": "wav",
    "*.aiff": "aiff",
    "*.mp3": "mp3",
    "*.flp": "flp",
    "*.smpack": "zip",
    "*.spec": "python"
  },
  "files.readonlyInclude": {
    "**/*.wav": true,
    "**/*.aiff": true,
    "**/*.mp3": true
  },

  // ── Editor quality-of-life ──────────────────────────────────────────────────
  "editor.renderWhitespace": "selection",
  "editor.lineNumbers": "on",
  "editor.tabSize": 4,
  "editor.rulers": [100],
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },
  "editor.suggestSelection": "first",
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.folding": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "breadcrumbs.enabled": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // ── GitHub Copilot ──────────────────────────────────────────────────────────
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true
  },
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,

  // ── Search and explorer (exclude build/cache artifacts) ─────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/.venv": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/node_modules": true,
    "**/target": true,
    "app/src-tauri/target": true,
    "plugin/build": true,
    "dist": true,
    "build": true
  },
  "search.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/node_modules": true,
    "app/src-tauri/target": true,
    "plugin/build": true,
    "dist": true,
    "build": true,
    "pnpm-lock.yaml": true,
    "Cargo.lock": true
  },
  "files.watcherExclude": {
    "**/__pycache__/**": true,
    "**/.venv/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/node_modules/**": true,
    "**/target/**": true,
    "app/src-tauri/target/**": true,
    "plugin/build/**": true
  },

  // ── WSL2 / cross-platform ───────────────────────────────────────────────────
  "files.eol": "\n",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.env.linux": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },

  // ── Source control ──────────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,

  // ── Spell check (cSpell) ────────────────────────────────────────────────────
  "cSpell.language": "en",
  "cSpell.ignorePaths": [
    "**/.venv/**",
    "**/node_modules/**",
    "**/target/**",
    "pnpm-lock.yaml",
    "Cargo.lock",
    "uv.lock",
    "**/*.wav",
    "**/*.aiff",
    "**/*.mp3",
    "**/*.flp",
    "**/__pycache__/**",
    "**/*.pyc",
    ".git/**"
  ],
  "cSpell.words": [
    "samplemind",
    "smpack",
    "SampleMind",
    "ruff",
    "uv",
    "pyproject",
    "platformdirs",
    "conftest",
    "pytest",
    "soundfile",
    "librosa",
    "soxr",
    "scipy",
    "numpy",
    "dtype",
    "alembic",
    "sqlmodel",
    "SQLModel",
    "tauri",
    "svelte",
    "runes",
    "vite",
    "htmx",
    "pnpm",
    "clippy",
    "worktree",
    "juce",
    "JUCE",
    "vst3",
    "VST3",
    "aufx",
    "auval",
    "aiff",
    "AIFF",
    "bpm",
    "BPM",
    "MIDI",
    "midi",
    "IAC",
    "osascript",
    "AppleScript",
    "notarization",
    "notarize",
    "entitlements",
    "codesign",
    "dylib",
    "xcframework",
    "WSL",
    "WSL2",
    "IPC",
    "HMR",
    "SSE",
    "sse",
    "multimodal",
    "sidecar",
    "stdin",
    "stdout",
    "stderr"
  ],
  "cSpell.enabledFileTypes": {
    "python": true,
    "rust": true,
    "svelte": true,
    "typescript": true,
    "markdown": true,
    "json": true,
    "toml": true,
    "plaintext": true
  },

  // ── Markdown lint ───────────────────────────────────────────────────────────
  "markdownlint.config": {
    "extends": ".markdownlint.json"
  },
  "editor.codeActions.triggerOnFocusChange": true,
  "cmake.ignoreCMakeListsMissing": true
}
